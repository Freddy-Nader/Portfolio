#!/bin/bash

# Define content directory
POSTS_DIR="content/posts"

read -p "Copy contents to clipboard and press ENTER."

# Get content from clipboard
CONTENT=$(pbpaste)

if [ -z "$CONTENT" ]; then
    echo "ERROR: Clipboard is empty."
    exit 1
fi

# Extract title, date, and tldr
TITLE=$(echo "$CONTENT" | sed -n '1p' | sed 's/^#* *//')
DATE_LINE=$(echo "$CONTENT" | sed -n '3p')
DATE=$(date -j -f "%B %d, %Y" "$DATE_LINE" "+%Y-%m-%d")
TLDR_LINE=$(echo "$CONTENT" | sed -n '5p')

# Debug
echo "TITLE: $TITLE"
echo "DATE: $DATE_LINE"
echo "PARSED DATE: $DATE"
echo "TL;DR: $(echo "$TLDR_LINE" | cut -d' ' -f1-7)..."

# Slug
SLUG=$(echo "$TITLE" | tr '[:upper:]' '[:lower:]' | tr -cs '[:alnum:]' '-' | sed 's/^-//;s/-$//')
FILENAME="$POSTS_DIR/$DATE-$SLUG.md"

if [ -f "$FILENAME" ]; then
    read -p "OVERWRITE '$FILENAME'? (y/N) " confirm
    [[ "$confirm" =~ ^[Yy]$ ]] || exit 0
fi

# Write File
echo "$CONTENT" > "$FILENAME"

echo "NEW POST: $FILENAME"
